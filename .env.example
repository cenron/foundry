# foundry — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

DATABASE_URL=postgres://foundry:foundry@localhost:5432/foundry?sslmode=disable
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
ANTHROPIC_API_KEY=
GIT_TOKEN=
FOUNDRY_AGENT_LIBRARY=./agents
FOUNDRY_SSH_KEY_PATH=~/.ssh
FOUNDRY_HOME=~/foundry
FOUNDRY_CLAUDE_VERSION=latest
